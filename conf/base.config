// Resource labels - keep science modules declaring only a label,
// so the engine (not the code) decides CPU/mem per environment.
process {
    withLabel:process_low    { cpus = 1;  memory = 2.GB  }
    withLabel:process_medium { cpus = 2;  memory = 4.GB }
    withLabel:process_high   { cpus = 4; memory = 6.GB }
    errorStrategy = 'retry'
    maxRetries    = 1
}

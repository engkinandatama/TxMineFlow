// TxMineFlow - top-level Nextflow config
manifest {
    name            = 'txmineflow'
    description     = 'Systematic mining of public tumor transcriptome collections'
    version         = '0.1.0'
    nextflowVersion = '>=23.10.0'
}

workDir = '.nextflow_work'

params {
    // populated by the txmineflow CLI from the project YAML
    project      = null
    outdir       = 'results'
    // stage toggles (mirror the project config)
    run_fetch    = true
    run_quant    = true
    run_mining   = true
    run_subtype  = false   // STAGE 3 - stub
    run_compare  = false   // STAGE 5 - stub
}

profiles {
    docker      { docker.enabled = true }
    singularity { singularity.enabled = true }
    test        { includeConfig 'conf/test.config' }
}

includeConfig 'conf/base.config'

executor {
    queueSize = 20
    submitRateLimit = '1 sec'
}

process {
    // Batasi resource default agar tidak "rakus"
    cpus = 4
    memory = '8.GB'
    maxForks = 8
}
